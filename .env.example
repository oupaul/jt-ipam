# =====================================================================
# jt-ipam 環境變數範例 — 複製為 .env 後填入實際值，**勿提交 .env 至 git**
# 安全提醒（OWASP A02 / A05）：
#   * 所有 SECRET 類欄位必須使用密碼學上隨機產生的長字串（≥ 32 bytes）
#   * 正式環境建議改用秘密管理工具（HashiCorp Vault / AWS KMS / Doppler）
#   * 切勿沿用範例值或字典常見字串
# =====================================================================

# -------------------- Application --------------------
APP_ENV=development          # development | staging | production
APP_DEBUG=true               # production 必須為 false
APP_LOG_LEVEL=INFO
APP_TIMEZONE=Asia/Taipei

# 對外 URL（**強制 https://** — A02 / 專案規定）
# 開發本機可用：https://localhost:5173（前端）或 https://localhost:8443（後端 direct TLS）
APP_PUBLIC_URL=https://localhost:5173
API_PUBLIC_URL=https://localhost:8443

# CORS 允許來源（逗號分隔；prod 不可使用 *；prod 必須 https://）
CORS_ORIGINS=https://localhost:5173

# -------------------- Secrets (A02 / A07) --------------------
# JWT 簽章金鑰（≥ 32 bytes，建議 openssl rand -hex 64）
SECRET_KEY=__CHANGE_ME__generate_with_openssl_rand_hex_64

# 應用層加密主金鑰（用於加密 DB 內 SNMP community / DNS 帳密 / API token）
# 建議 openssl rand -base64 32
ENCRYPTION_KEY=__CHANGE_ME__base64_32_bytes

# Argon2id 密碼雜湊參數（不要降低；高負載環境可調 time_cost/parallelism）
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST_KIB=65536
ARGON2_PARALLELISM=4

# Token 與 Session 設定
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14
SESSION_COOKIE_SECURE=true   # prod 必須 true（HTTPS only）
SESSION_COOKIE_SAMESITE=lax  # lax | strict | none

# -------------------- TLS（強制 SSL；A02）--------------------
# 兩種模式擇一：
#
# 模式 1：nginx 反代 HTTPS（建議，預設）
#   * 後端 uvicorn 綁 127.0.0.1:8000 純 HTTP（loopback only）
#   * nginx 終結 HTTPS（憑證走 certbot Let's Encrypt 或內網 CA）
#   * 設定如下：
#       BACKEND_TLS_MODE=nginx
#       BACKEND_BIND_HOST=127.0.0.1
#       BACKEND_BIND_PORT=8000
#       # BACKEND_TLS_CERT_FILE / BACKEND_TLS_KEY_FILE 不需設定
#
# 模式 2：後端直接 TLS（自簽憑證適合內網 / 極簡部署）
#   * uvicorn 直接吃 cert/key
#   * 自簽憑證請先跑：sudo ./scripts/generate-self-signed-cert.sh
#   * 設定如下：
#       BACKEND_TLS_MODE=direct
#       BACKEND_BIND_HOST=0.0.0.0
#       BACKEND_BIND_PORT=8443
#       BACKEND_TLS_CERT_FILE=/etc/jt-ipam/tls/server.crt
#       BACKEND_TLS_KEY_FILE=/etc/jt-ipam/tls/server.key
#
BACKEND_TLS_MODE=nginx
BACKEND_BIND_HOST=127.0.0.1
BACKEND_BIND_PORT=8000
# BACKEND_TLS_CERT_FILE=/etc/jt-ipam/tls/server.crt
# BACKEND_TLS_KEY_FILE=/etc/jt-ipam/tls/server.key

# -------------------- Database (PostgreSQL 16) --------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=jt_ipam
POSTGRES_USER=jt_ipam
POSTGRES_PASSWORD=__CHANGE_ME__strong_random_password

# 連線池（async）
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# -------------------- Redis 7 --------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=__CHANGE_ME__strong_random_password
REDIS_DB=0

# -------------------- Rate Limiting (A04 / A07) --------------------
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute       # 登入端點較嚴
RATE_LIMIT_API_TOKEN=600/minute # 透過 API Token 認證的呼叫

# -------------------- Audit Log (A08 / A09) --------------------
# SHA-256 異動鏈起始種子（部署後不可變更，否則整條鏈失效）
AUDIT_CHAIN_GENESIS=__CHANGE_ME__random_hex_64

# Graylog GELF 外送（可空白以停用）
GRAYLOG_HOST=
GRAYLOG_PORT=12201
GRAYLOG_FACILITY=jt-ipam

# -------------------- SSRF Allowlist (A10) --------------------
# 對外整合（DNS server、LibreNMS、Webhook）允許連線的目標 CIDR / 主機
# 預設禁止 link-local、loopback、metadata IP；以下白名單可額外放行
OUTBOUND_ALLOW_CIDRS=
OUTBOUND_ALLOW_HOSTS=
# 是否允許連到 RFC1918 私網（內網 IPAM 通常需要）
OUTBOUND_ALLOW_PRIVATE=true

# -------------------- SMTP（Email 通知）--------------------
# 設定後可用 POST /api/v1/notifications/email/test 驗證
# tls_mode: starttls（建議）/ tls（純 SMTPS 465）/ none（僅內網/隔離環境）
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=jt-ipam@your-domain.tld
SMTP_TLS_MODE=starttls
SMTP_TIMEOUT=10

# -------------------- Frontend --------------------
VITE_API_BASE_URL=http://localhost:8000
VITE_DEFAULT_LOCALE=zh-TW
VITE_DEFAULT_THEME=auto

# -------------------- Optional: 外部整合（Phase 2+） --------------------
# 設定後存入 DB 的加密欄位，這裡只放 bootstrap 預設值
LIBRENMS_DEFAULT_URL=
LIBRENMS_DEFAULT_TOKEN=
POWERDNS_DEFAULT_URL=
POWERDNS_DEFAULT_API_KEY=
